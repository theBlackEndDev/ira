{
  "hooks": {
    "SessionStart": [
      { "matcher": "", "hooks": [{ "type": "command", "command": "node hooks/scripts/context-loader.mjs", "timeout": 5000 }] }
    ],
    "UserPromptSubmit": [
      { "matcher": "", "hooks": [{ "type": "command", "command": "node hooks/scripts/keyword-detector.mjs", "timeout": 5000 }] },
      { "matcher": "", "hooks": [{ "type": "command", "command": "node hooks/scripts/agent-router.mjs",   "timeout": 15000 }] }
    ],
    "PreToolUse": [
      { "matcher": "", "hooks": [{ "type": "command", "command": "node hooks/scripts/boundary-enforcer.mjs", "timeout": 3000 }] }
    ],
    "PostToolUse": [
      { "matcher": "", "hooks": [{ "type": "command", "command": "node hooks/scripts/state-sync.mjs", "timeout": 3000 }] }
    ],
    "PreCompact": [
      { "matcher": "", "hooks": [{ "type": "command", "command": "node hooks/scripts/context-saver.mjs", "timeout": 10000 }] }
    ],
    "Stop": [
      { "matcher": "", "hooks": [{ "type": "command", "command": "node hooks/scripts/ralph-loop.mjs", "timeout": 10000 }] }
    ],
    "SessionEnd": [
      { "matcher": "", "hooks": [{ "type": "command", "command": "node hooks/scripts/session-harvester.mjs", "timeout": 30000 }] }
    ]
  }
}
