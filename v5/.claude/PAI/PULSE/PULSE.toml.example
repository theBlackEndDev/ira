# PAI Pulse Configuration
# Copy this file to PULSE.toml and customize for your setup

[pulse]
port = 31337
host = "localhost"

[modules]
# Enable/disable modules by setting to true/false
hooks = true
observability = true

# Example custom module — create your own in modules/
# my_module = true

[voice]
enabled = false
# voice_id = "YOUR_ELEVENLABS_VOICE_ID"
# api_key_env = "ELEVENLABS_API_KEY"

[notifications]
enabled = true

[checks]
# Health check interval in seconds
interval = 300
# Add your custom checks in checks/
