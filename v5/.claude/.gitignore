**/.wrangler/
**/.playwright-cli/
**/bun.lock

# PAI Release builds
PAI_RELEASES/
PAI/PAI_RELEASES/

# ── MEMORY (top-level, Claude Code auto-memory) ────
# Index and memory files are small — track them.
# Ignore only runtime state.
MEMORY/STATE/algorithms/
MEMORY/STATE/kitty-sessions/
MEMORY/STATE/current-work-*.json
MEMORY/SECURITY/

