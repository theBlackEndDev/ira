# Claude Code internal directories
file-history/
shell-snapshots/
session-env/
paste-cache/
chrome/
node_modules/
**/node_modules/

# Session/runtime state
debug/
todos/

# Statsig analytics (Claude Code creates this)
[Ss]tatsig/

# Bun build cache
*.bun-build

# Accidental npm/bun debris at root
/package.json
/package-lock.json
/bun.lock

# Accidental CLI-flag/URL files at root — agent-browser/playwright misuse
# where flags or URLs get written as positional filenames. Root-anchored so
# real dirs deeper in the tree aren't affected.
/--full-page
/--full
/--url
/http:
/https:

# Interceptor screenshot dumps at root — callers must `cd /tmp/pai-screenshots`
# before `interceptor screenshot --save`. Root-anchored so legitimate captures
# stored deeper (e.g. under MEMORY/) aren't affected.
/interceptor-screenshot-*.jpg
/interceptor-screenshot-*.png

# Orphaned dev server logs
WebsiteDevServer/

# System state files
*.cache
*.log
*-cache.json

# Embedded repos
plugins/marketplaces/browser-tools/
scratchpad/dotfiles-private-repo/
history/recovery/snapshots/
*.onnx
*.tar.gz

# Credentials — NEVER commit
PAI/USER/CREDENTIALS/
PAI/.env

# TLS certs (generated locally by mkcert)
PAI/PULSE/certs/

# ── PAI MEMORY ──────────────────────────────────────
# Track the DISTILLED knowledge, ignore the RAW inputs.
# Raw session data gets parsed into Knowledge, Wisdom, and Research —
# track the output, not the input.
#
# TRACKED: KNOWLEDGE/, RESEARCH/, WISDOM/, RELATIONSHIP/, BOOKMARKS/,
#          PAISYSTEMUPDATES/, PROJECT/, REFERENCE/, SKILLS/, AUTO/, DATA/, RAW/
#
# IGNORED: raw/large/transient inputs that feed the distilled outputs:

# 2.3 GB — 12K JSONL algorithm reflections (raw input)
PAI/MEMORY/LEARNING/
# Session PRDs (MEMORY/WORK) are TRACKED — they are the Algorithm's
# durable record of each run and must survive across machines/recovery.
# 91 MB — tool/agent event logs
PAI/MEMORY/OBSERVABILITY/
# 16 MB — security scan logs
PAI/MEMORY/SECURITY/
# Runtime state (ephemeral, regenerated)
PAI/MEMORY/STATE/
# Voice event logs (runtime)
PAI/MEMORY/VOICE/
# Archived data
PAI/MEMORY/ARCHIVE/
# Generated vector embeddings (regenerated)
PAI/MEMORY/KNOWLEDGE/_embeddings/
# Pending harvest items (transient queue)
PAI/MEMORY/KNOWLEDGE/_harvest-queue/

# ── PAI USER ────────────────────────────────────────
# ARBOL/ is its own git repo — keep ignored
PAI/USER/ARBOL/
PAI/USER/CREDENTIALS/
PAI/USER/browser-state/
PAI/USER/FINANCES/
PAI/USER/HEALTH/
PAI/USER/Plans/

